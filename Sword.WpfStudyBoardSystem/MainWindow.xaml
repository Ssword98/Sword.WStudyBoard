<Window x:Class="Sword.WpfStudyBoardSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        mc:Ignorable="d"
        Title="MODBUS学习卡监控系统" Height="760" Width="1180" Background="#FFFFFF">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
        <Style x:Key="TopLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#333"/>
        </Style>
        <Style x:Key="StatusButtonStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="86"/>
            <Setter Property="Height" Value="66"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="#D8E8F8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}" BorderBrush="#cfcfcf" BorderThickness="1" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="#A7D7A7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- 标题 -->
            <RowDefinition Height="Auto"/> <!-- 串口条 -->
            <RowDefinition Height="Auto"/> <!-- 仪表区域容器 -->
            <RowDefinition Height="*"/>    <!-- 曲线 + 状态 -->
            <RowDefinition Height="Auto"/> <!-- 状态栏 -->
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <DockPanel Grid.Row="0" Margin="4" LastChildFill="True">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <Image Source="/Assets/Images/Logo.png" Width="44" Height="44" Margin="6,0"/>
                <TextBlock Text="朝夕教育 - MODBUS学习卡监控系统" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Margin="6,0"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center" Margin="0,0,6,0">
                <TextBlock x:Name="lblConnectionStatus" Text="已断开学习卡连接!" Foreground="#2EA44F" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <Button Content="关闭" Width="72" Height="30" Click="CloseButton_Click" Background="#E0E0E0"/>
            </StackPanel>
        </DockPanel>

        <!-- 串口设置 -->
        <Border Grid.Row="1" Background="#F6F6F6" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,8,0,8">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="串口" Style="{StaticResource TopLabel}" Margin="4,0"/>
                <ComboBox x:Name="cmbPorts" Width="96" Margin="4,0"/>
                <Button Content="刷新" Click="RefreshPorts_Click" Width="60" Margin="8,0"/>

                <TextBlock Text="波特率" Style="{StaticResource TopLabel}" Margin="12,0,0,0"/>
                <ComboBox x:Name="cmbBaudRate" Width="100" SelectedIndex="0" Margin="4,0">
                    <ComboBoxItem Content="9600"/>
                    <ComboBoxItem Content="19200"/>
                    <ComboBoxItem Content="38400"/>
                    <ComboBoxItem Content="115200"/>
                </ComboBox>

                <TextBlock Text="校验位" Style="{StaticResource TopLabel}" Margin="12,0,0,0"/>
                <ComboBox x:Name="cmbParity" Width="90" SelectedIndex="0" Margin="4,0">
                    <ComboBoxItem Content="None"/>
                    <ComboBoxItem Content="Odd"/>
                    <ComboBoxItem Content="Even"/>
                </ComboBox>

                <TextBlock Text="数据位" Style="{StaticResource TopLabel}" Margin="12,0,0,0"/>
                <ComboBox x:Name="cmbDataBits" Width="60" SelectedIndex="1" Margin="4,0">
                    <ComboBoxItem Content="8"/>
                    <ComboBoxItem Content="7"/>
                </ComboBox>

                <TextBlock Text="停止位" Style="{StaticResource TopLabel}" Margin="12,0,0,0"/>
                <ComboBox x:Name="cmbStopBits" Width="70" SelectedIndex="0" Margin="4,0">
                    <ComboBoxItem Content="1"/>
                    <ComboBoxItem Content="2"/>
                </ComboBox>

                <Button x:Name="btnConnect" Content="连接设备" Click="ConnectButton_Click" Background="#2E86C1" Foreground="White" Width="110" Height="30" Margin="16,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- 仪表与 OLED 区（带浅色边框） -->
        <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#E6E6E6" BorderThickness="1" CornerRadius="3" Padding="12" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="320"/>
                </Grid.ColumnDefinitions>

                <!-- 三个仪表占位 -->
                <StackPanel Grid.Column="0" Orientation="Vertical">
                    <GroupBox Header="温度" Margin="6" Padding="8" Height="220">
                        <Grid>
                            <Viewbox Stretch="Uniform">
                                <Canvas Width="220" Height="220">
                                    <Ellipse Width="220" Height="220" Fill="#F8FBFF" Stroke="#D6D6D6" StrokeThickness="1"/>
                                    <Line X1="110" Y1="110" X2="110" Y2="30" Stroke="#E94B35" StrokeThickness="3">
                                        <Line.RenderTransform>
                                            <RotateTransform x:Name="tempNeedleRotate" Angle="38" CenterX="110" CenterY="110"/>
                                        </Line.RenderTransform>
                                    </Line>
                                    <Ellipse Width="36" Height="36" Fill="#33A1FF" Canvas.Left="92" Canvas.Top="92"/>
                                    <TextBlock x:Name="tempValueText" Text="32.8" FontSize="20" FontWeight="Bold" Foreground="White" Canvas.Left="92" Canvas.Top="92" TextAlignment="Center"/>
                                </Canvas>
                            </Viewbox>
                            <StackPanel VerticalAlignment="Bottom" Margin="4">
                                <TextBlock Text="[历史最高] 66 ℃" FontSize="12"/>
                                <TextBlock Text="[历史最低] 32.8 ℃" FontSize="12" Margin="0,4,0,0"/>
                                <CheckBox Content="启用模拟" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Grid>
                    </GroupBox>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Vertical">
                    <GroupBox Header="湿度" Margin="6" Padding="8" Height="220">
                        <Grid>
                            <Viewbox Stretch="Uniform">
                                <Canvas Width="220" Height="220">
                                    <Ellipse Width="220" Height="220" Fill="#F8FBFF" Stroke="#D6D6D6" StrokeThickness="1"/>
                                    <Line X1="110" Y1="110" X2="110" Y2="30" Stroke="#E94B35" StrokeThickness="3">
                                        <Line.RenderTransform>
                                            <RotateTransform x:Name="humidNeedleRotate" Angle="110" CenterX="110" CenterY="110"/>
                                        </Line.RenderTransform>
                                    </Line>
                                    <Ellipse Width="36" Height="36" Fill="#33A1FF" Canvas.Left="92" Canvas.Top="92"/>
                                    <TextBlock x:Name="humidValueText" Text="63" FontSize="20" FontWeight="Bold" Foreground="White" Canvas.Left="92" Canvas.Top="92" TextAlignment="Center"/>
                                </Canvas>
                            </Viewbox>
                            <StackPanel VerticalAlignment="Bottom" Margin="4">
                                <TextBlock Text="[历史最高] 86 %" FontSize="12"/>
                                <TextBlock Text="[历史最低] 56 %" FontSize="12" Margin="0,4,0,0"/>
                                <CheckBox Content="启用模拟" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Grid>
                    </GroupBox>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Vertical">
                    <GroupBox Header="亮度" Margin="6" Padding="8" Height="220">
                        <Grid>
                            <Viewbox Stretch="Uniform">
                                <Canvas Width="220" Height="220">
                                    <Ellipse Width="220" Height="220" Fill="#F8FBFF" Stroke="#D6D6D6" StrokeThickness="1"/>
                                    <Line X1="110" Y1="110" X2="110" Y2="30" Stroke="#E94B35" StrokeThickness="3">
                                        <Line.RenderTransform>
                                            <RotateTransform x:Name="brightNeedleRotate" Angle="108" CenterX="110" CenterY="110"/>
                                        </Line.RenderTransform>
                                    </Line>
                                    <Ellipse Width="36" Height="36" Fill="#33A1FF" Canvas.Left="92" Canvas.Top="92"/>
                                    <TextBlock x:Name="brightValueText" Text="60" FontSize="20" FontWeight="Bold" Foreground="White" Canvas.Left="92" Canvas.Top="92" TextAlignment="Center"/>
                                </Canvas>
                            </Viewbox>
                            <StackPanel VerticalAlignment="Bottom" Margin="4">
                                <TextBlock Text="[历史最高] 79 cd/m²" FontSize="12"/>
                                <TextBlock Text="[历史最低] 1 cd/m²" FontSize="12" Margin="0,4,0,0"/>
                                <CheckBox Content="启用模拟" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Grid>
                    </GroupBox>
                </StackPanel>

                <!-- OLED 显示 -->
                <GroupBox Grid.Column="3" Header="OLED显示屏" Margin="6" Padding="8" Height="220">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="1" Background="#3C3C3C" BorderBrush="#BDBDBD" BorderThickness="1" Margin="4" Height="110">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <TextBlock x:Name="oledDisplay" Text="NiHao" Foreground="#00E5FF" FontFamily="Consolas" FontSize="16" Margin="8" TextWrapping="Wrap"/>
                            </ScrollViewer>
                        </Border>
                        <TextBlock Grid.Row="2" Text="输入显示的字符串(英文-60)" Margin="4,8,4,2"/>
                        <TextBox Grid.Row="3" x:Name="txtOledInput" Text="NiHao" Margin="4" Height="48"/>
                        <Button Content="发送文本" Click="SendOledText_Click" HorizontalAlignment="Right" Width="100" Margin="4" VerticalAlignment="Bottom"/>
                    </Grid>
                </GroupBox>

            </Grid>
        </Border>

        <!-- 下部：曲线 + 状态监控 -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- 实时曲线 -->
            <GroupBox Header="&gt;&gt; 实时曲线" Margin="0,0,8,0" Grid.Column="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <lvc:CartesianChart x:Name="realTimeChart" Series="{Binding SeriesCollection}" Grid.Row="0" Margin="6">
                        <lvc:CartesianChart.AxisX>
                            <lvc:Axis Title="时间" Labels="{Binding Labels}"/>
                        </lvc:CartesianChart.AxisX>
                        <lvc:CartesianChart.AxisY>
                            <lvc:Axis Title="值" MinValue="0" MaxValue="100"/>
                        </lvc:CartesianChart.AxisY>
                    </lvc:CartesianChart>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="6">
                        <CheckBox Content="温度" IsChecked="True" Checked="ChartVisibility_Changed" Unchecked="ChartVisibility_Changed" Margin="6,0"/>
                        <CheckBox Content="湿度" IsChecked="True" Checked="ChartVisibility_Changed" Unchecked="ChartVisibility_Changed" Margin="6,0"/>
                        <CheckBox Content="亮度" IsChecked="True" Checked="ChartVisibility_Changed" Unchecked="ChartVisibility_Changed" Margin="6,0"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <!-- 状态监控 -->
            <GroupBox Header="&gt;&gt; 状态监控" Grid.Column="1" Margin="0,0,0,0">
                <UniformGrid Columns="3" Rows="2" Margin="8">
                    <ToggleButton Style="{StaticResource StatusButtonStyle}" Content="一号&#x0a;灯珠"/>
                    <ToggleButton Style="{StaticResource StatusButtonStyle}" Content="二号&#x0a;灯珠"/>
                    <ToggleButton Style="{StaticResource StatusButtonStyle}" Content="三号&#x0a;灯珠"/>
                    <ToggleButton Style="{StaticResource StatusButtonStyle}" Content="四号&#x0a;灯珠"/>
                    <ToggleButton Style="{StaticResource StatusButtonStyle}" Content="五号&#x0a;灯珠"/>
                    <ToggleButton Style="{StaticResource StatusButtonStyle}" Content="统一&#x0a;控制" Background="#F4C271"/>
                </UniformGrid>
            </GroupBox>
        </Grid>

        <!-- 状态栏 -->
        <StatusBar Grid.Row="4" Background="#F6F6F6" Height="28" Margin="0,8,0,0">
            <StatusBarItem>
                <TextBlock x:Name="statusText" Text="就绪" Margin="6,0"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding CurrentTime}" Margin="0,0,12,0"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
